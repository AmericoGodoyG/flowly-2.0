# Flowly Assistente - environment template
# Copy to .env for local development. In cloud, configure these as runtime secrets/env vars.

# Backend Flowly API used to execute commands and validate users.
FLOWLY_API_BASE_URL=https://SEU_BACKEND_URL/api
FLOWLY_API_TIMEOUT_SEC=20
FLOWLY_MATCH_THRESHOLD=78
FLOWLY_CORS_ORIGIN=https://SEU_FRONTEND_URL

# REST mode receives the user JWT through Authorization: Bearer <token>.
# Keep empty in cloud. Use only for local CLI/manual tests.
FLOWLY_API_TOKEN=
FLOWLY_USER_TYPE=

# Analytics stored directly in the same application MongoDB.
FLOWLY_ANALYTICS_STORAGE=mongodb
FLOWLY_MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/Flowly?retryWrites=true&w=majority
FLOWLY_MONGO_DB=Flowly
FLOWLY_ANALYTICS_COLLECTION=assistantinsights

# Queue mode.
# local works in Cloud Run for the current lightweight background mining.
# Use celery + Redis only when you deploy a separate worker service.
FLOWLY_ANALYTICS_QUEUE_MODE=local
FLOWLY_LOCAL_WORKER_THREADS=2
FLOWLY_CONVERSATION_STORE=/tmp/flowly_conversation_state.json
FLOWLY_CONVERSATION_TTL_SEC=900

# Browser voice/TTS contract.
FLOWLY_LANGUAGE=pt-BR
FLOWLY_TTS_ENABLED=true

# Internal upload moderation endpoint called by the API.
# Must match flowly_api UPLOAD_MODERATION_SECRET if UPLOAD_MODERATION_URL points here.
UPLOAD_MODERATION_SECRET=GERAR_UM_SEGREDO_LONGO_IGUAL_NA_API

# Debug
FLOWLY_DEBUG=false

# Local development example
# FLOWLY_API_BASE_URL=http://localhost:5000/api
# FLOWLY_CORS_ORIGIN=*
# FLOWLY_MONGO_URI=mongodb://localhost:27017/Flowly

# Optional production queue with separate worker.
# FLOWLY_ANALYTICS_QUEUE_MODE=celery
# FLOWLY_REDIS_URL=redis://HOST:6379/0
# FLOWLY_CELERY_RESULT_BACKEND=redis://HOST:6379/0

# Optional fallback storage.
# FLOWLY_ANALYTICS_STORAGE=jsonl
# FLOWLY_ANALYTICS_STORE=/tmp/analytics_events.jsonl

# Optional legacy analytics HTTP ingestion.
# FLOWLY_ANALYTICS_INGEST_URL=https://SEU_BACKEND_URL/api/admin/assistant-insights/ingest
# FLOWLY_ANALYTICS_READ_URL=https://SEU_BACKEND_URL/api/admin/assistant-insights
# FLOWLY_ANALYTICS_SECRET=GERAR_UM_SEGREDO_LONGO
