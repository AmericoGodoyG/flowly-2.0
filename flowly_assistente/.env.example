# Flowly Assistente - example

# Backend Flowly usado para executar comandos e validar usuário.
FLOWLY_API_BASE_URL=http://localhost:5000/api
FLOWLY_API_TIMEOUT_SEC=20
FLOWLY_MATCH_THRESHOLD=78
FLOWLY_CORS_ORIGIN=*

# REST: o token vem do frontend via Authorization: Bearer <token>.
# Deixe vazio. Use apenas para CLI local.
FLOWLY_API_TOKEN=
FLOWLY_USER_TYPE=

# Analytics gravado direto no MongoDB da aplicação.
FLOWLY_ANALYTICS_STORAGE=mongodb
FLOWLY_MONGO_URI=mongodb://localhost:27017/Flowly
FLOWLY_MONGO_DB=Flowly
FLOWLY_ANALYTICS_COLLECTION=assistantinsights

# Fila local: dispara mineração em thread sem Redis.
FLOWLY_ANALYTICS_QUEUE_MODE=local
FLOWLY_CONVERSATION_STORE=data/conversation_state.json

# Frontend/voz no navegador.
FLOWLY_LANGUAGE=pt-BR
FLOWLY_TTS_ENABLED=true

# Debug
FLOWLY_DEBUG=false

# --- Produção/nuvem, se usar worker real ---
# FLOWLY_ANALYTICS_QUEUE_MODE=celery
# FLOWLY_REDIS_URL=redis://localhost:6379/0
# FLOWLY_CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Fallback local em arquivo, se não quiser Mongo ---
# FLOWLY_ANALYTICS_STORAGE=jsonl
# FLOWLY_ANALYTICS_STORE=data/analytics_events.jsonl

# --- Somente se voltar a salvar analytics via API Node interna ---
# FLOWLY_ANALYTICS_INGEST_URL=https://sua-api/api/admin/assistant-insights/ingest
# FLOWLY_ANALYTICS_READ_URL=https://sua-api/api/admin/assistant-insights
# FLOWLY_ANALYTICS_SECRET=um_segredo_longo_aleatorio
