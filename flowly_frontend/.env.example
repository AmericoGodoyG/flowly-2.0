# Flowly Frontend - build-time environment template
# React embeds REACT_APP_* values during build. Configure these in CI/CD before build.

# Production / cloud
REACT_APP_API_URL=https://SEU_BACKEND_URL/api
REACT_APP_API_PUBLIC_URL=https://SEU_BACKEND_URL
REACT_APP_SOCKET_URL=https://SEU_BACKEND_URL
REACT_APP_ASSISTANT_URL=https://SEU_ASSISTENTE_URL

# Local development example
# REACT_APP_API_URL=http://localhost:5000/api
# REACT_APP_API_PUBLIC_URL=http://localhost:5000
# REACT_APP_SOCKET_URL=http://localhost:5000
# REACT_APP_ASSISTANT_URL=http://localhost:8080
