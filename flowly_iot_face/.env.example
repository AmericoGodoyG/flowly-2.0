# Host e porta do microserviço de reconhecimento facial
HOST=0.0.0.0
PORT=5001

# Modelo DeepFace (VGG-Face recomendado para demo)
FACE_MODEL=VGG-Face

# Detector de rosto (opencv é leve; retinaface é mais preciso e mais pesado)
FACE_DETECTOR=opencv

# Limiar de distância cosseno — menor = mais rigoroso (ajuste conforme testes)
FACE_MATCH_THRESHOLD=0.46
FACE_VERIFY_THRESHOLD=0.50
