# Flowly API - environment template
# Copy to .env for local development. In cloud, configure these as runtime secrets/env vars.

# Runtime
PORT_ENV=5000
NODE_ENV=production
CORS_ORIGIN=https://SEU_FRONTEND_URL
FRONTEND_URL=https://SEU_FRONTEND_URL

# MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER/Flowly?retryWrites=true&w=majority

# Auth
JWT_SECRET=GERAR_UM_SEGREDO_LONGO_COM_32_BYTES_OU_MAIS
JWT_EXPIRES_IN=7d

# Face recognition service
FACE_SERVICE_URL=http://localhost:5001
FACE_MATCH_THRESHOLD=0.46
FACE_VERIFY_THRESHOLD=0.50
FACE_DUPLICATE_THRESHOLD=0.46
FACE_SESSION_EXPIRES_IN=5m
FACE_ENROLL_SESSION_EXPIRES_IN=10m
BODY_SIZE_LIMIT=20mb

# Google Cloud Storage / Vision
GCP_PROJECT_ID=SEU_GCP_PROJECT_ID
GCP_BUCKET_NAME=SEU_BUCKET_GCS
# Local only. In Cloud Run, prefer attaching a service account to the service.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.local.json

# Upload content safety
# Images are moderated with Google Vision before cloud upload.
UPLOAD_IMAGE_MODERATION_PROVIDER=google_vision
UPLOAD_IMAGE_MODERATION_REQUIRED=true
# Optional additional moderation endpoint, for example flowly_assistente.
# UPLOAD_MODERATION_URL=https://SEU_ASSISTENTE_URL/api/v1/uploads/moderate
# UPLOAD_MODERATION_SECRET=GERAR_UM_SEGREDO_LONGO_IGUAL_NO_ASSISTENTE
# UPLOAD_MODERATION_REQUIRED=false
UPLOAD_MODERATION_MAX_BYTES=10485760

# Internal assistant analytics ingestion via HTTP.
# Not required when flowly_assistente writes analytics directly to MongoDB.
# ASSISTANT_ANALYTICS_SECRET=GERAR_UM_SEGREDO_LONGO_SE_USAR_INGEST_HTTP

# Email / SMTP
HOST=smtp.example.com
EMAIL_PORT=587
SECURE=false
AUTH_EMAIL=no-reply@example.com
AUTH_PASSWORD=SENHA_DO_SMTP
SERVICE=example
